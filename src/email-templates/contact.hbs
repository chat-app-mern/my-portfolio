<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>New Contact Form Submission</title>
<style type="text/css">
    body { margin: 0; padding: 0; font-family: 'Segoe UI', Arial, sans-serif; background-color: #f4f4f4; color: #333; }
    table { border-collapse: collapse; }
    .highlight { color: #FF3C3C; font-weight: bold; }
    @media only screen and (max-width: 600px) {
        table[class="container"] { width: 95% !important; }
        td[class="header"] { font-size: 20px !important; padding: 15px !important; }
        td[class="content"] { padding: 15px !important; font-size: 16px !important; line-height: 22px !important; }
    }
</style>
</head>
<body>
<table width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#f4f4f4">
    <tr><td height="30"></td></tr>
    <tr>
        <td align="center">
            <table class="container" width="600" cellpadding="0" cellspacing="0" border="0" bgcolor="#ffffff" style="border:1px solid #dddddd; border-radius: 8px; overflow: hidden;">
                <tr>
                    <td class="header" bgcolor="#121212" style="padding:20px; text-align:center; color:#ffffff; font-size:22px; font-weight:bold;">
                        New Contact Form Submission
                    </td>
                </tr>
                <tr>
                    <td class="content" style="padding:25px; font-size:15px; line-height:1.6; color:#333;">
                        <p style="text-align: center; font-size: 16px; margin-bottom: 20px;">
                            You have received a new message from your portfolio contact form.
                        </p>
                        
                        <div style="background-color: #f9f9f9; padding: 20px; border-radius: 6px; border-left: 5px solid #FF3C3C;">
                            <p style="margin: 0 0 10px 0;"><strong>Name:</strong> {{name}}</p>
                            <p style="margin: 0 0 10px 0;"><strong>Email:</strong> <a href="mailto:{{email}}" style="color:#FF3C3C; text-decoration:none;">{{email}}</a></p>
                            <p style="margin: 0 0 10px 0;"><strong>Subject:</strong> {{subject}}</p>
                            <p style="margin: 15px 0 5px 0;"><strong>Message:</strong></p>
                            <p style="margin: 0; white-space: pre-wrap; font-style: normal; color: #444;">{{message}}</p>
                        </div>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr><td height="30"></td></tr>
</table>
</body>
</html>
